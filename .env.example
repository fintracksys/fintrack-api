# MySQL connection string (Prisma)
# Local example (with password): mysql://USER:PASSWORD@localhost:3306/db_fintrack_nest
# Local example (no password): mysql://root@localhost:3306/db_fintrack_nest
DATABASE_URL="mysql://root@localhost:3306/db_fintrack_nest"

# JWT signing secret (required in production)
JWT_SECRET="change_me_in_production"

# API port (default: 3001)
PORT=3001
